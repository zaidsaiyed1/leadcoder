{
              "builds": [{
                  "src": "leadcoder/wsgi.py",
                  "use": "@vercel/python",
                  "config": { "maxLambdaSize": "15mb","runtime":"python3.11.3" }
              }],
              "routes": [
                  {
                      "src": "/(.*)",
                      "dest": "leadcoder/wsgi.py"
                  }
              ],
          

          

            "rewrites": [
              { "source": "/", "destination": "/api/index" }
            ]

          }